{
  "name": "opencode-ssh-session",
  "version": "0.2.0",
  "description": "OpenCode plugin for persistent SSH sessions with shell state persistence",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --external @opencode-ai/plugin",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.1.51",
    "@biomejs/biome": "^2.3.0",
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.0"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "ssh",
    "remote",
    "session"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PedroKlein/opencode-ssh-session"
  }
}
